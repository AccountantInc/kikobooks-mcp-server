        "globals": "^16.0.0",
        "prettier": "^3.8.1",
        "shx": "^0.3.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
